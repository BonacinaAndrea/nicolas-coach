<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- SEO TITLE & DESCRIPTION -->  
  <title>{{ title }} | NP Performance Coach</title>
  <meta name="description" content="{{ description or 'Preparatore atletico per calciatori. Allenamento personalizzato online e in presenza — con metodo scientifico e risultati misurabili.' }}">

  <!-- CANONICAL -->
  <link rel="canonical" href="https://npperformance.it{{ page.url }}">

  <!-- ROBOTS -->
  <meta name="robots" content="index, follow">

  <!-- OPEN GRAPH -->
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="NP Performance Coach">
  <meta property="og:title" content="{{ title }} | NP Performance Coach">
  <meta property="og:description" content="{{ description or 'Preparatore atletico per calciatori. Allenamento personalizzato online e in presenza — con metodo scientifico e risultati misurabili.' }}">
  <meta property="og:url" content="https://npperformance.it{{ page.url }}">
  <meta property="og:image" content="https://npperformance.it/assets/img/og-image.jpg">
  <meta property="og:locale" content="it_IT">

  <!-- TWITTER CARD -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title }} | NP Performance Coach">
  <meta name="twitter:description" content="{{ description or 'Preparatore atletico per calciatori. Allenamento personalizzato online e in presenza — con metodo scientifico e risultati misurabili.' }}">
  <meta name="twitter:image" content="https://npperformance.it/assets/img/og-image.jpg">

  <!-- STRUCTURED DATA — LocalBusiness + Person -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Person",
        "@id": "https://npperformance.it/#nicolas",
        "name": "Nicolas Previtali",
        "jobTitle": "Preparatore atletico",
        "description": "Calciatore professionista in Serie C (Giana Erminio), laureato in preparazione atletica. Preparatore atletico per calciatori online e in presenza.",
        "url": "https://npperformance.it",
        "sameAs": [
          "https://www.instagram.com/np.performance.coach",
          "https://www.tiktok.com/@np.performance.coach"
        ],
        "worksFor": {
          "@type": "SportsTeam",
          "name": "Giana Erminio",
          "sport": "Calcio"
        }
      },
      {
        "@type": "LocalBusiness",
        "@id": "https://npperformance.it/#business",
        "name": "NP Performance Coach",
        "description": "Preparazione atletica personalizzata per calciatori. Coaching calcio online e in presenza in Lombardia.",
        "url": "https://npperformance.it",
        "telephone": "",
        "areaServed": [
          { "@type": "Country", "name": "Italia" },
          { "@type": "AdministrativeArea", "name": "Lombardia" }
        ],
        "serviceType": [
          "Preparazione atletica calcio",
          "Coaching calcio online",
          "Personal trainer calcio"
        ],
        "founder": { "@id": "https://npperformance.it/#nicolas" },
        "sameAs": [
          "https://www.instagram.com/np.performance.coach",
          "https://www.tiktok.com/@np.performance.coach"
        ]
      }
    ]
  }
  </script>

  <link rel="stylesheet" href="/assets/css/style.css">
</head>
<body>
<nav class="nav" role="navigation" aria-label="Menu principale">
  <a href="/" class="nav-logo" aria-label="NP Performance Coach - Home">
    <img src="/assets/img/logo.png" alt="NP Performance Coach logo" width="44" height="44">
    <span class="nav-logo-text">NP Performance</span>
  </a>
  <ul class="nav-links" id="navLinks">
    <li><a href="/chi-e/">Chi sono</a></li>
    <li><a href="/servizi/">Servizi</a></li>
    <li><a href="/casi-studio/">Risultati</a></li>
    <li><a href="/prenota/" class="nav-cta">Prenota consulenza</a></li>
  </ul>
  <div class="nav-hamburger" onclick="toggleNav()" aria-label="Menu" aria-expanded="false">
    <span></span><span></span><span></span>
  </div>
</nav>
<main>
  {{ content | safe }}
</main>
<footer class="footer" role="contentinfo">
  <div class="footer-logo">
    <img src="/assets/img/logo.png" alt="NP Performance Coach" width="40" height="40">
    <span>NP Performance</span>
  </div>
  <nav aria-label="Footer navigation" class="footer-nav">
    <ul class="footer-links">
      <li><a href="/chi-e/">Chi sono</a></li>
      <li><a href="/servizi/">Servizi</a></li>
      <li><a href="/casi-studio/">Risultati</a></li>
      <li><a href="/prenota/">Prenota</a></li>
    </ul>
  </nav>
  <div class="footer-social">
    <a aria-label="Seguici su Instagram" class="social-icon" href="https://www.instagram.com/np.performance.coach" rel="noopener noreferrer" target="_blank">
      <svg aria-hidden="true" fill="none" height="22" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="22">
        <rect height="20" rx="5" width="20" x="2" y="2"></rect>
        <circle cx="12" cy="12" r="4"></circle>
        <circle cx="17.5" cy="6.5" fill="currentColor" r="1.2" stroke="none"></circle>
      </svg>
      <span class="social-label">Instagram</span>
    </a>
    <a aria-label="Seguici su TikTok" class="social-icon" href="https://www.tiktok.com/@np.performance.coach" rel="noopener noreferrer" target="_blank">
      <svg aria-hidden="true" fill="currentColor" height="22" viewBox="0 0 24 24" width="22">
        <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.34 6.34 0 0 0-6.13 6.29 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z"></path>
      </svg>
      <span class="social-label">TikTok</span>
